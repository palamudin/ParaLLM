{
  "armId": "para-grok-full-triple",
  "title": "Para Grok 4.20 Triple",
  "description": "xAI provider-owned Para run with three Grok 4.20 reasoning adversarial lanes and a Grok 4.20 reasoning summarizer.",
  "type": "steered",
  "runtime": {
    "executionMode": "live",
    "contextMode": "full",
    "directBaselineMode": "off",
    "provider": "xai",
    "model": "grok-4.20-reasoning",
    "summarizerProvider": "xai",
    "summarizerModel": "grok-4.20-reasoning",
    "summarizerHarness": {
      "concision": "balanced",
      "structure": true,
      "factsFirst": true,
      "counterposition": true,
      "extraInstruction": "Be explicit, methodical, and factual. Separate assumptions from verified facts, and keep sequencing operational."
    },
    "reasoningEffort": "xhigh",
    "targetTimeouts": {
      "commander": 240,
      "workerDefault": 300,
      "commanderReview": 420,
      "summarizer": 300,
      "answerNow": 240,
      "arbiter": 300
    },
    "budget": {
      "maxTotalTokens": 280000,
      "maxCostUsd": 24,
      "maxOutputTokens": 3600
    },
    "research": {
      "enabled": false,
      "externalWebAccess": true,
      "domains": []
    },
    "vetting": {
      "enabled": true
    },
    "preferredLoop": {
      "rounds": 1,
      "delayMs": 0
    },
    "requireLive": true,
    "allowMockFallback": false
  },
  "workers": [
    {
      "id": "A",
      "type": "proponent",
      "label": "Proponent",
      "role": "utility",
      "focus": "benefits, feasibility, leverage, momentum, practical execution",
      "temperature": "balanced",
      "model": "grok-4.20-reasoning"
    },
    {
      "id": "B",
      "type": "sceptic",
      "label": "Sceptic",
      "role": "adversarial",
      "focus": "failure modes, downside, hidden coupling, consequences, externalities",
      "temperature": "cool",
      "model": "grok-4.20-reasoning"
    },
    {
      "id": "C",
      "type": "security",
      "label": "Security",
      "role": "adversarial",
      "focus": "security abuse, privilege escalation, hostile actors",
      "temperature": "hot",
      "model": "grok-4.20-reasoning"
    }
  ]
}
